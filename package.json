{
  "name": "astro-paper-v6",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro check && astro build && pagefind --site dist && cp -r dist/pagefind public/",
    "preview": "astro preview",
    "sync": "astro sync",
    "astro": "astro",
    "format:check": "prettier --check .",
    "format": "prettier --write .",
    "lint": "eslint .",
    "upload:assets": "rclone copy -v dist/_astro r2:blog-assets/_astro --fast-list --checksum --transfers 8",
    "upload:pagefind": "rclone copy -v dist/pagefind r2:blog-assets/pagefind --fast-list --checksum --transfers 8",
    "clean:assets": "rm -rf dist/_astro",
    "clean:pagefind": "rm -rf dist/pagefind",
    "deploy": "wrangler deploy",
    "release": "bun run build && bun run upload:assets && bun run clean:assets && bun run deploy"
  },
  "dependencies": {
    "@astrojs/mdx": "^5.0.6",
    "@astrojs/react": "^5.0.5",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "@giscus/react": "^3.1.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "astro": "^6.3.3",
    "beautiful-mermaid": "github:2017fighting/beautiful-mermaid#dist",
    "dayjs": "^1.11.20",
    "hast-util-from-html-isomorphic": "^2.0.0",
    "hast-util-to-string": "^3.0.0",
    "lodash.kebabcase": "^4.1.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "remark-collapse": "^0.1.2",
    "remark-toc": "^9.0.0",
    "satori": "^0.26.0",
    "sharp": "^0.34.5",
    "slugify": "^1.6.9",
    "tailwindcss": "^4.3.0",
    "unist-util-visit": "^5.0.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@pagefind/default-ui": "^1.5.2",
    "@shikijs/transformers": "^4.0.2",
    "@tailwindcss/typography": "^0.5.19",
    "@types/bun": "^1.3.14",
    "@types/lodash.kebabcase": "^4.1.9",
    "@typescript-eslint/parser": "^8.59.3",
    "eslint": "^10.4.0",
    "eslint-plugin-astro": "^1.7.0",
    "pagefind": "^1.5.2",
    "prettier": "3.8.3",
    "prettier-plugin-astro": "0.14.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "typescript": "^6.0.3",
    "wrangler": "^4.94.0"
  }
}
